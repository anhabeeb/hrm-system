{
  "name": "hrm-system",
  "version": "0.1.0",
  "private": true,
  "description": "Cloudflare Workers + D1 HRM system",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply hrm-system --local",
    "db:migrate:remote": "wrangler d1 migrations apply hrm-system --remote",
    "db:execute:local": "wrangler d1 execute hrm-system --local --command",
    "db:execute:remote": "wrangler d1 execute hrm-system --remote --command"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  }
}
