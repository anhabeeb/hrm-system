{
  "name": "hrm-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "build": "npm run build:all",
    "build:api": "tsc --noEmit",
    "build:frontend": "npm --prefix frontend install && npm --prefix frontend run build",
    "build:all": "npm run build:api && npm run build:frontend && npm run verify:frontend-assets && npm run verify:critical-routes && npm run verify:document-schema && npm run verify:salary-schema && npm run verify:approval-schema && npm run verify:compensation-schema && npm run verify:payroll-schema && npm run verify:payslip-schema && npm run verify:employee-lifecycle-schema && npm run verify:offboarding-schema && npm run verify:contract-schema && npm run verify:roster-schema && npm run verify:attendance-schema && npm run verify:biometric-schema && npm run verify:attendance-reports-schema && npm run verify:leave-balance-schema && npm run verify:leave-approval-schema && npm run verify:long-leave-schema && npm run verify:holiday-schema && npm run verify:notifications-schema && npm run verify:email-notifications-schema && npm run verify:expiry-alerts-schema && npm run verify:dashboard-schema && npm run verify:hr-reports-schema && npm run verify:payroll-reports-schema && npm run verify:export-print-schema && npm run verify:imports-schema && npm run verify:backup-restore-schema && npm run verify:data-retention-schema && npm run verify:permission-audit && npm run verify:security-hardening && npm run verify:no-todo-tests && npm run verify:performance-d1",
    "verify:frontend-assets": "node scripts/verify-frontend-assets.mjs",
    "verify:critical-routes": "node scripts/verify-critical-routes.mjs",
    "verify:document-schema": "node scripts/verify-document-schema.mjs",
    "verify:salary-schema": "node scripts/verify-salary-schema.mjs",
    "verify:approval-schema": "node scripts/verify-approval-schema.mjs",
    "verify:compensation-schema": "node scripts/verify-compensation-schema.mjs",
    "verify:payroll-schema": "node scripts/verify-payroll-schema.mjs",
    "verify:payslip-schema": "node scripts/verify-payslip-schema.mjs",
    "verify:employee-lifecycle-schema": "node scripts/verify-employee-lifecycle-schema.mjs",
    "verify:offboarding-schema": "node scripts/verify-offboarding-schema.mjs",
    "verify:contract-schema": "node scripts/verify-contract-schema.mjs",
    "verify:roster-schema": "node scripts/verify-roster-schema.mjs",
    "verify:attendance-schema": "node scripts/verify-attendance-schema.mjs",
    "verify:biometric-schema": "node scripts/verify-biometric-schema.mjs",
    "verify:attendance-reports-schema": "node scripts/verify-attendance-reports-schema.mjs",
    "verify:leave-balance-schema": "node scripts/verify-leave-balance-schema.mjs",
    "verify:leave-approval-schema": "node scripts/verify-leave-approval-schema.mjs",
    "verify:long-leave-schema": "node scripts/verify-long-leave-schema.mjs",
    "verify:holiday-schema": "node scripts/verify-holiday-schema.mjs",
    "verify:notifications-schema": "node scripts/verify-notifications-schema.mjs",
    "verify:email-notifications-schema": "node scripts/verify-email-notifications-schema.mjs",
    "verify:expiry-alerts-schema": "node scripts/verify-expiry-alerts-schema.mjs",
    "verify:dashboard-schema": "node scripts/verify-dashboard-schema.mjs",
    "verify:hr-reports-schema": "node scripts/verify-hr-reports-schema.mjs",
    "verify:payroll-reports-schema": "node scripts/verify-payroll-reports-schema.mjs",
    "verify:export-print-schema": "node scripts/verify-export-print-schema.mjs",
    "verify:imports-schema": "node scripts/verify-imports-schema.mjs",
    "verify:backup-restore-schema": "node scripts/verify-backup-restore-schema.mjs",
    "verify:data-retention-schema": "node scripts/verify-data-retention-schema.mjs",
    "verify:permission-audit": "node scripts/verify-permission-audit.mjs",
    "verify:dependency-security": "node scripts/verify-dependency-security.mjs",
    "verify:security-hardening": "node scripts/verify-security-hardening.mjs && npm run verify:dependency-security",
    "verify:toast-alerts": "node scripts/verify-toast-alerts.mjs",
    "verify:employee-login-assignment": "node scripts/verify-employee-login-assignment.mjs",
    "verify:page-layout": "node scripts/verify-page-layout.mjs",
    "verify:no-todo-tests": "node scripts/verify-no-todo-tests.mjs",
    "verify:performance-d1": "node scripts/verify-performance-d1.mjs",
    "verify:production-readiness": "node scripts/verify-production-readiness.mjs",
    "verify:production-acceptance": "node scripts/verify-production-acceptance.mjs",
    "clean:project": "node scripts/clean-project.mjs",
    "archive:clean": "node scripts/create-clean-archive.mjs",
    "archive:clean:script": "node scripts/create-clean-archive.mjs",
    "verify:clean-archive": "node scripts/verify-clean-archive.mjs",
    "deploy": "npm run build && wrangler deploy && npm run smoke:production",
    "smoke:users-access": "node scripts/smoke-users-access.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "acceptance:staging": "node scripts/acceptance-staging.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:remote": "wrangler d1 migrations apply DB --remote",
    "db:execute:local": "wrangler d1 execute DB --local --command \"SELECT 1 AS ok;\"",
    "db:execute:remote": "wrangler d1 execute DB --remote --command \"SELECT 1 AS ok;\""
  },
  "dependencies": {
    "hono": "^4.7.11",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250510.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.18.0"
  }
}
